generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum SodexEnvironment {
  mainnet
  testnet
}

enum WealthMode {
  alive
  guardian
  heir
}

enum ThesisStatus {
  active
  challenged
  invalidated
  confirmed
}

enum DecisionActionType {
  hold
  ssi_allocate
  sodex_trade
  wait
}

enum DecisionChoice {
  approved
  rejected
  deferred
}

enum DecisionOutcome {
  HIT
  STOP
  DRIFT
  PENDING
}

model UserProfile {
  id            String   @id @default(cuid())
  walletAddress String   @unique @map("wallet_address")
  displayName   String?  @map("display_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  wealthPolicy  WealthPolicy?
  sodexAccounts SodexAccount[]
  signedOrders  SignedOrder[]
  trades        Trade[]
  skillEvents   SkillEvent[]
  agentLogs     AgentLog[]
  theses        InvestmentThesis[]
  decisions     InvestmentDecision[]

  @@map("user_profiles")
}

model WealthPolicy {
  id             String     @id @default(cuid())
  userId         String     @unique @map("user_id")
  mode           WealthMode @default(alive)
  maxNotionalUsd Decimal    @default(100) @map("max_notional_usd") @db.Decimal(18, 2)
  allowlistJson  Json?      @map("allowlist_json")
  killSwitch     Boolean    @default(false) @map("kill_switch")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wealth_policies")
}

/// Per-user SoDEX account identity. aid comes from official GET /accounts/{address}/state.
/// NEVER use a global SODEX_ACCOUNT_ID env var for user trading.
model SodexAccount {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  walletAddress String           @map("wallet_address")
  environment   SodexEnvironment
  accountId     String           @map("account_id") // SoDEX aid
  verifiedAt    DateTime         @map("verified_at")
  rawStateJson  Json?            @map("raw_state_json")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([walletAddress, environment])
  @@index([accountId])
  @@map("sodex_accounts")
}

model SkillEvent {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  skillId   String   @map("skill_id")
  eventType String   @map("event_type")
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  user UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([skillId, createdAt])
  @@map("skill_events")
}

model Signal {
  id        String   @id @default(cuid())
  source    String
  symbol    String?
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([source, createdAt])
  @@map("signals")
}

model SignedOrder {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  walletAddress String           @map("wallet_address")
  environment   SodexEnvironment
  accountId     String           @map("account_id")
  market        String
  side          String
  orderType     String           @map("order_type")
  notionalUsd   Decimal?         @map("notional_usd") @db.Decimal(18, 6)
  payloadJson   Json             @map("payload_json")
  signature     String
  status        String           @default("pending")
  sodexOrderId  String?          @map("sodex_order_id")
  proofUrl      String?          @map("proof_url")
  errorMessage  String?          @map("error_message")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  user   UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@index([walletAddress, environment, createdAt])
  @@map("signed_orders")
}

model Trade {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  signedOrderId String?          @map("signed_order_id")
  environment   SodexEnvironment
  market        String
  side          String
  size          String
  price         String?
  fee           String?
  sodexTradeId  String?          @map("sodex_trade_id")
  rawJson       Json?            @map("raw_json")
  createdAt     DateTime         @default(now()) @map("created_at")

  user        UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  signedOrder SignedOrder? @relation(fields: [signedOrderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("trades")
}

model AgentLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  provider  String
  model     String
  event     String
  detail    String?
  latencyMs Int?     @map("latency_ms")
  costUsd   Decimal? @map("cost_usd") @db.Decimal(18, 8)
  createdAt DateTime @default(now()) @map("created_at")

  user UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([provider, createdAt])
  @@map("agent_logs")
}

model AgentMeta {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("agent_meta")
}

model Attestation {
  id        String   @id @default(cuid())
  subject   String
  kind      String
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([subject, kind])
  @@map("attestations")
}

model ActionLogRef {
  id        String   @id @default(cuid())
  refType   String   @map("ref_type")
  refId     String   @map("ref_id")
  ipfsCid   String?  @map("ipfs_cid")
  txHash    String?  @map("tx_hash")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([refType, refId])
  @@map("action_log_refs")
}

/// A tracked investment belief, created by the AI partner or the user.
/// Confidence and status evolve as evidence changes — this is the Investment
/// Memory that makes HEIRLOCK a partner rather than a stateless chatbot.
model InvestmentThesis {
  id           String       @id @default(cuid())
  userId       String       @map("user_id")
  statement    String
  status       ThesisStatus @default(active)
  confidence   Int          @default(50)
  source       String       @default("ai") // "ai" | "user"
  evidenceJson Json?        @map("evidence_json")
  invalidatedReason String? @map("invalidated_reason")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user      UserProfile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  decisions InvestmentDecision[]

  @@index([userId, status, createdAt])
  @@map("investment_theses")
}

/// One node on the Decision Timeline: a proposal the partner surfaced, what
/// the user chose to do about it, and — once known — the outcome. This is
/// the persisted record that "why" and "what changed" are built from.
model InvestmentDecision {
  id              String              @id @default(cuid())
  userId          String              @map("user_id")
  thesisId        String?             @map("thesis_id")
  actionType      DecisionActionType  @map("action_type")
  proposalJson    Json                @map("proposal_json")
  userChoice      DecisionChoice?     @map("user_choice")
  outcome         DecisionOutcome?    @default(PENDING)
  livingLoopHash  String?             @map("living_loop_hash")
  debateJson      Json?               @map("debate_json")
  policyJson      Json?               @map("policy_json")
  fillProofJson   Json?               @map("fill_proof_json")
  signedOrderId   String?             @map("signed_order_id")
  citationsJson   Json?               @map("citations_json")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  user   UserProfile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  thesis InvestmentThesis? @relation(fields: [thesisId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("investment_decisions")
}

/// One per wallet per UTC day — the evidence digest the "What changed since
/// yesterday" feature diffs against. Cheap append-only snapshot, not a cache.
model MarketSnapshot {
  id            String   @id @default(cuid())
  walletAddress String   @map("wallet_address")
  day           DateTime @db.Date
  payloadJson   Json     @map("payload_json")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([walletAddress, day])
  @@map("market_snapshots")
}

model AiProviderMetric {
  id           String   @id @default(cuid())
  provider     String
  model        String
  successCount Int      @default(0) @map("success_count")
  failureCount Int      @default(0) @map("failure_count")
  totalLatency Int      @default(0) @map("total_latency_ms")
  costUsd      Decimal  @default(0) @map("cost_usd") @db.Decimal(18, 8)
  day          DateTime @db.Date
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([provider, model, day])
  @@map("ai_provider_metrics")
}
