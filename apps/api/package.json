{
  "name": "@heirlock/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:soso": "tsx src/soso/e2e-soso.ts",
    "test:local": "tsx src/e2e-local-stack.ts",
    "test:trade": "tsx src/e2e-testnet-trade.ts",
    "test:perps": "tsx src/e2e-testnet-perps.ts",
    "test:fund-gas": "tsx src/e2e-fund-testnet-gas.ts",
    "test:ai": "tsx src/e2e-ai.ts",
    "test:ssi": "tsx src/e2e-ssi.ts",
    "test:all-e2e": "pnpm test && pnpm test:local && pnpm test:soso && pnpm test:ssi && pnpm test:ai && pnpm test:trade && pnpm test:perps",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@heirlock/ai-provider": "workspace:*",
    "@heirlock/config": "workspace:*",
    "@heirlock/sodex-signing": "workspace:^",
    "@prisma/client": "^6.5.0",
    "@upstash/redis": "^1.38.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "pino": "^9.6.0",
    "siwe": "^3.0.0",
    "viem": "^2.55.0",
    "ws": "^8.21.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.1",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
