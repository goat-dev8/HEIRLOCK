# HEIRLOCK — Production Environment Example
# Validated against official docs: 2026-07-11
# Mainnet is primary. Testnet values included for labeled testing only.
#
# DO NOT commit real secrets. Inject secrets via Render / Supabase dashboards.
# Copy to Render env or use as checklist — never invent secrets.
#
# ARCHITECTURE: Per-user SoDEX relay (no global trading keys) · NVIDIA-primary AI · Supabase Postgres

NODE_ENV=production
PORT=10000
HOST=0.0.0.0
LOG_LEVEL=info

HEIRLOCK_DEFAULT_PROFILE=mainnet-limited
HEIRLOCK_ALLOW_TESTNET=false

FRONTEND_URL=<REQUEST_FROM_USER>
CORS_ALLOWED_ORIGINS=<REQUEST_FROM_USER>
API_PUBLIC_URL=<REQUEST_FROM_USER>

# Supabase PostgreSQL
DATABASE_URL=<REQUEST_FROM_USER>
DIRECT_DATABASE_URL=<REQUEST_FROM_USER>
REDIS_URL=<REQUEST_FROM_USER>

JWT_SECRET=<REQUEST_FROM_USER>
SIWE_DOMAIN=<REQUEST_FROM_USER>
SIWE_URI=<REQUEST_FROM_USER>
CRON_SECRET=<REQUEST_FROM_USER>
WALLET_ENCRYPT_KEY=<REQUEST_FROM_USER>

# --- SoSoValue (official) ---
SOSO_BASE_URL=https://openapi.sosovalue.com/openapi/v1
SOSO_API_KEY=<REQUEST_FROM_USER>
SOSO_API_KEY_2=<REQUEST_FROM_USER>
SOSO_RATE_LIMIT_RPM=20
SOSO_MONTHLY_QUOTA=100000

# --- ValueChain Mainnet (official) ---
VALUECHAIN_MAINNET_CHAIN_ID=286623
VALUECHAIN_MAINNET_RPC=https://mainnet.valuechain.xyz
VALUECHAIN_MAINNET_WS=wss://mainnet-ws.valuechain.xyz
VALUECHAIN_MAINNET_EXPLORER=https://main-scan.valuechain.xyz
VALUECHAIN_NATIVE_SYMBOL=SOSO
VALUECHAIN_NATIVE_DECIMALS=18
WSOSO_ADDRESS=0x5050505050505050505050505050505050505050

# --- ValueChain Testnet (official; CI only when HEIRLOCK_ALLOW_TESTNET=true) ---
VALUECHAIN_TESTNET_CHAIN_ID=138565
VALUECHAIN_TESTNET_RPC=https://testnet-v2.valuechain.xyz
VALUECHAIN_TESTNET_WS=wss://testnet-v2-ws.valuechain.xyz
VALUECHAIN_TESTNET_EXPLORER=https://test-scan.valuechain.xyz

WEALTH_POLICY_ADDRESS=0xB4483128Bf95aa63621cB9EcA7f5d22a0d546b6C
MODE_CONTROLLER_ADDRESS=0xdBAE8db588e39Ba5EBe2C749Ba06Daf24F6F3450
ACTION_LOG_ADDRESS=0x3db8750EE3a397b5A8A4e1842Bfb69f511342C6b
ATTESTATION_REGISTRY_ADDRESS=0x3C1f4718a45e80c6D4E8772909712c1599D8D51D
CONTINUITY_NFT_ADDRESS=0xD7464d9182ffe02d7255Cf3e319145755eE8517d
FEE_COLLECTOR_ADDRESS=0x16F3B1b67461B20F889998A059526E2acfcdf060
DEPLOYER_PRIVATE_KEY=<REQUEST_FROM_USER>

# --- SoDEX Mainnet (official public gateways) ---
# User aid is resolved per wallet and stored in Supabase — NOT as a global env identity.
SODEX_MAINNET_SPOT_REST=https://mainnet-gw.sodex.dev/api/v1/spot
SODEX_MAINNET_PERPS_REST=https://mainnet-gw.sodex.dev/api/v1/perps
SODEX_MAINNET_SPOT_WS=wss://mainnet-gw.sodex.dev/ws/spot
SODEX_MAINNET_PERPS_WS=wss://mainnet-gw.sodex.dev/ws/perps
SODEX_MAINNET_APP_URL=https://sodex.com
SODEX_MAINNET_CHAIN_ID=286623

SODEX_TESTNET_SPOT_REST=https://testnet-gw.sodex.dev/api/v1/spot
SODEX_TESTNET_PERPS_REST=https://testnet-gw.sodex.dev/api/v1/perps
SODEX_TESTNET_SPOT_WS=wss://testnet-gw.sodex.dev/ws/spot
SODEX_TESTNET_PERPS_WS=wss://testnet-gw.sodex.dev/ws/perps
SODEX_TESTNET_APP_URL=https://testnet.sodex.com
SODEX_TESTNET_CHAIN_ID=138565

SODEX_EIP712_VERSION=1
SODEX_EIP712_VERIFYING_CONTRACT=0x0000000000000000000000000000000000000000
SODEX_EIP712_SPOT_NAME=spot
SODEX_EIP712_PERPS_NAME=futures

TRADING_ENABLED=true
TRADING_MAX_NOTIONAL_USD=100
KILL_SWITCH_TRADING=false
TRADING_ALLOWLIST=<REQUEST_FROM_USER>

# Optional Guardian automation only — never a shared user trading account
SODEX_GUARDIAN_API_KEY_NAME=<REQUEST_FROM_USER>
SODEX_GUARDIAN_API_KEY_PRIVATE_KEY=<REQUEST_FROM_USER>
SODEX_GUARDIAN_MASTER_ADDRESS=<REQUEST_FROM_USER>

# --- SSI / Base ---
BASE_CHAIN_ID=8453
BASE_RPC_URL=https://mainnet.base.org
BASE_EXPLORER=https://basescan.org
SOSO_TOKEN_ETHEREUM=0x76a0e27618462bdac7a29104bdcfff4e6bfcea2d
SOSO_TOKEN_BASE=0x624e2e7fdc8903165f64891672267ab0fcb98831
SSI_APP_URL=https://ssi.sosovalue.com
SSI_EARN_URL=https://ssi.sosovalue.com/earn
SSI_REWARD_URL=https://ssi.sosovalue.com/reward
SSI_ROUTER_ADDRESS=<REQUEST_FROM_USER>
SSI_STAKING_ADDRESS=<REQUEST_FROM_USER>
SSI_RESEARCH_HUB_VOTING_ADDRESS=<REQUEST_FROM_USER>

# --- AI: NVIDIA primary ---
NVIDIA_API_KEY=<REQUEST_FROM_USER>
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_PRIMARY=deepseek-ai/deepseek-v4-flash
NVIDIA_MODEL_SECONDARY=meta/llama-3.1-70b-instruct
NVIDIA_MODEL_TERTIARY=nvidia/llama-3.1-nemotron-70b-instruct
NVIDIA_TIMEOUT_MS=120000
NVIDIA_THINKING_ENABLED=true
NVIDIA_REASONING_EFFORT=high

CEREBRAS_API_KEY=<REQUEST_FROM_USER>
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama-3.3-70b

SAMBANOVA_API_KEY=<REQUEST_FROM_USER>
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct

GROQ_API_KEY=<REQUEST_FROM_USER>
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

AI_PRIMARY_PROVIDER=nvidia
AI_FALLBACK_PROVIDERS=cerebras,sambanova,groq
AI_REQUEST_TIMEOUT_MS=120000
AI_MAX_RETRIES=2
AI_CIRCUIT_BREAKER_THRESHOLD=5
AI_CIRCUIT_BREAKER_COOLDOWN_MS=60000

REOWN_PROJECT_ID=<REQUEST_FROM_USER>
RESEND_API_KEY=<REQUEST_FROM_USER>
EMAIL_FROM=<REQUEST_FROM_USER>
TELEGRAM_BOT_TOKEN=<REQUEST_FROM_USER>
TELEGRAM_ALLOWED_CHAT_IDS=<REQUEST_FROM_USER>
PINATA_JWT=<REQUEST_FROM_USER>
SENTRY_DSN=<REQUEST_FROM_USER>
