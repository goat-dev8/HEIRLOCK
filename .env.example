# HEIRLOCK — Environment Template
# Copy to .env (never commit .env).
# Public infrastructure values are filled from official SoSoValue / SoDEX / ValueChain / NVIDIA docs.
# Secrets use <REQUEST_FROM_USER> — never invent them.
# See SETUP_REQUIREMENTS.md for how to obtain every placeholder.
#
# ARCHITECTURE LOCK (2026-07-11):
# - SoDEX: per-user non-custodial relay. NEVER use global SODEX_PRIVATE_KEY / SODEX_ADDRESS / SODEX_ACCOUNT_ID for user trading.
# - AI: NVIDIA primary → NVIDIA fallbacks → Cerebras → SambaNova → Groq
# - Database: Supabase PostgreSQL
# - Frontend env (VITE_*) is deferred until backend DoD

# =============================================================================
# RUNTIME
# =============================================================================
NODE_ENV=development
PORT=10000
HOST=0.0.0.0
LOG_LEVEL=info

# Profiles: mainnet-limited | mainnet | mainnet-readonly | testnet
HEIRLOCK_DEFAULT_PROFILE=mainnet-limited
HEIRLOCK_ALLOW_TESTNET=true

# =============================================================================
# APP URLS (fill after deploy targets known)
# =============================================================================
FRONTEND_URL=http://localhost:5173
# Where: Vercel project URL or custom domain (later)
# Official: https://vercel.com/docs

CORS_ALLOWED_ORIGINS=http://localhost:5173
# Comma-separated exact origins

API_PUBLIC_URL=http://localhost:10000
# Where: Render service URL after first deploy
# Official: https://render.com/docs

# =============================================================================
# DATABASE — Supabase PostgreSQL (Prisma)
# =============================================================================
DATABASE_URL=<REQUEST_FROM_USER>
# Where: Supabase → Project Settings → Database → Connection string (URI)
# Prefer Transaction pooler (port 6543) + ?pgbouncer=true for runtime
# Why: users, policies, sodex_accounts, skills, signed_orders, audit
# Official: https://supabase.com/docs/guides/database/connecting-to-postgres
# Time: 5–10 min

DIRECT_DATABASE_URL=<REQUEST_FROM_USER>
# Where: Supabase → Session mode / direct connection (port 5432)
# Why: Prisma migrate deploy against primary, not pooler
# Time: 2 min

# =============================================================================
# REDIS
# =============================================================================
# Redis — prefer Upstash REST (or classic REDIS_URL)
UPSTASH_REDIS_REST_URL=<REQUEST_FROM_USER>
UPSTASH_REDIS_REST_TOKEN=<REQUEST_FROM_USER>
# Where: https://console.upstash.com/ → Redis → REST API
REDIS_URL=<REQUEST_FROM_USER>
# Optional alternative to Upstash REST (redis:// / rediss://)

# =============================================================================
# AUTH / SECRETS
# =============================================================================
JWT_SECRET=<REQUEST_FROM_USER>
# How: openssl rand -hex 32
# Why: SIWE session JWTs (HS256)
# Required: strong random ≥32 bytes
# Time: 1 min

SIWE_DOMAIN=localhost
# Example production: heirlock.vercel.app (no protocol)
# Why: SIWE message domain binding

SIWE_URI=http://localhost:5173
# Example production: https://heirlock.vercel.app

CRON_SECRET=<REQUEST_FROM_USER>
# How: openssl rand -hex 24
# Why: authorize Render cron / heartbeat endpoints

WALLET_ENCRYPT_KEY=<REQUEST_FROM_USER>
# How: openssl rand -hex 32
# Why: AES-256-GCM if any sensitive material ever stored (prefer non-custodial)
# Note: user SoDEX keys are NEVER stored

# =============================================================================
# SOSOVALUE OPENAPI (official)
# Source: https://sosovalue-1.gitbook.io/sosovalue-api-doc
# =============================================================================
SOSO_BASE_URL=https://openapi.sosovalue.com/openapi/v1
SOSO_API_KEY=<REQUEST_FROM_USER>
# Where: https://sosovalue.com/developer/dashboard
# Header: x-soso-api-key
# Limits: 20 req/min, 100,000 req/month
# Official: https://sosovalue-1.gitbook.io/sosovalue-api-doc/setting-up-your-api-key.md

SOSO_API_KEY_2=<REQUEST_FROM_USER>
# Optional failover key

SOSO_RATE_LIMIT_RPM=20
SOSO_MONTHLY_QUOTA=100000

# =============================================================================
# VALUECHAIN EVM (official)
# Source: https://sodex.com/documentation/about-valuechain/how-valuechain-works/about-valuechain-evm
# =============================================================================
VALUECHAIN_MAINNET_CHAIN_ID=286623
VALUECHAIN_MAINNET_RPC=https://mainnet.valuechain.xyz
VALUECHAIN_MAINNET_WS=wss://mainnet-ws.valuechain.xyz
VALUECHAIN_MAINNET_EXPLORER=https://main-scan.valuechain.xyz
VALUECHAIN_NATIVE_SYMBOL=SOSO
VALUECHAIN_NATIVE_DECIMALS=18

VALUECHAIN_TESTNET_CHAIN_ID=138565
VALUECHAIN_TESTNET_RPC=https://testnet-v2.valuechain.xyz
VALUECHAIN_TESTNET_WS=wss://testnet-v2-ws.valuechain.xyz
VALUECHAIN_TESTNET_EXPLORER=https://test-scan.valuechain.xyz

WSOSO_ADDRESS=0x5050505050505050505050505050505050505050

# HEIRLOCK contracts — ValueChain MAINNET (chainId 286623) — deployed 2026-07-11
# Artifact: contracts/deployments/valuechain-mainnet.json
WEALTH_POLICY_ADDRESS=0xB4483128Bf95aa63621cB9EcA7f5d22a0d546b6C
MODE_CONTROLLER_ADDRESS=0xdBAE8db588e39Ba5EBe2C749Ba06Daf24F6F3450
ACTION_LOG_ADDRESS=0x3db8750EE3a397b5A8A4e1842Bfb69f511342C6b
ATTESTATION_REGISTRY_ADDRESS=0x3C1f4718a45e80c6D4E8772909712c1599D8D51D
CONTINUITY_NFT_ADDRESS=0xD7464d9182ffe02d7255Cf3e319145755eE8517d
FEE_COLLECTOR_ADDRESS=0x16F3B1b67461B20F889998A059526E2acfcdf060

# HEIRLOCK contracts — ValueChain TESTNET (chainId 138565) — deployed 2026-07-11
# Artifact: contracts/deployments/valuechain-testnet.json
# Gas funded via official SoDEX EVM_WITHDRAW (no public withdraw UI)
WEALTH_POLICY_ADDRESS_TESTNET=0x3C1f4718a45e80c6D4E8772909712c1599D8D51D
MODE_CONTROLLER_ADDRESS_TESTNET=0x16F3B1b67461B20F889998A059526E2acfcdf060
ACTION_LOG_ADDRESS_TESTNET=0xD7464d9182ffe02d7255Cf3e319145755eE8517d
ATTESTATION_REGISTRY_ADDRESS_TESTNET=0xfdC9A9F19441f10729769393CBBD6d870802Ace9
CONTINUITY_NFT_ADDRESS_TESTNET=0x273F1874E1acAe0aa74F04DaeAb718E1CD8d287B
FEE_COLLECTOR_ADDRESS_TESTNET=0xBd9dB4C0F048527358a8A6050fA3b5d31a49D067

DEPLOYER_PRIVATE_KEY=<REQUEST_FROM_USER>
# Dedicated deployer wallet only — NEVER a user trading key
# Risk: CRITICAL secret

# =============================================================================
# SODEX GATEWAYS (official — public URLs only)
# Source: https://sodex.com/documentation/trading-api/trading-api
# Architecture: per-user aid stored in Supabase after verify-account.
# FORBIDDEN for user trading: SODEX_PRIVATE_KEY, SODEX_ADDRESS, SODEX_ACCOUNT_ID
# =============================================================================
SODEX_MAINNET_SPOT_REST=https://mainnet-gw.sodex.dev/api/v1/spot
SODEX_MAINNET_PERPS_REST=https://mainnet-gw.sodex.dev/api/v1/perps
SODEX_MAINNET_SPOT_WS=wss://mainnet-gw.sodex.dev/ws/spot
SODEX_MAINNET_PERPS_WS=wss://mainnet-gw.sodex.dev/ws/perps
SODEX_MAINNET_APP_URL=https://sodex.com
SODEX_MAINNET_CHAIN_ID=286623

SODEX_TESTNET_SPOT_REST=https://testnet-gw.sodex.dev/api/v1/spot
SODEX_TESTNET_PERPS_REST=https://testnet-gw.sodex.dev/api/v1/perps
SODEX_TESTNET_SPOT_WS=wss://testnet-gw.sodex.dev/ws/spot
SODEX_TESTNET_PERPS_WS=wss://testnet-gw.sodex.dev/ws/perps
SODEX_TESTNET_APP_URL=https://testnet.sodex.com
SODEX_TESTNET_CHAIN_ID=138565

SODEX_EIP712_VERSION=1
SODEX_EIP712_VERIFYING_CONTRACT=0x0000000000000000000000000000000000000000
SODEX_EIP712_SPOT_NAME=spot
SODEX_EIP712_PERPS_NAME=futures

# Trading policy controls (server-side)
TRADING_ENABLED=true
# Mainnet hard ceiling ≤1 USDC for all tests/trades
TRADING_MAX_NOTIONAL_USD=1
MAINNET_TEST_MAX_NOTIONAL_USD=1
# Testnet may use larger sizes for integration tests
TESTNET_TEST_MAX_NOTIONAL_USD=100000
KILL_SWITCH_TRADING=false
TRADING_ALLOWLIST=
# Mainnet only when non-empty. Testnet ignores allowlist (SoDEX verified aid is the gate).
# Empty = all wallets on mainnet too.

# LOCAL TEST WALLET ONLY — never multi-user production identity
# Use for local/testnet/mainnet-smoke (≤1 USDC) only. Product users bring their own wallets.
SODEX_LOCAL_TEST_WALLET_ONLY=true
SODEX_TEST_PRIVATE_KEY=<REQUEST_FROM_USER>
SODEX_TEST_ADDRESS=<REQUEST_FROM_USER>
SODEX_TEST_ACCOUNT_ID=<REQUEST_FROM_USER>
# Legacy aliases accepted locally (same meaning as SODEX_TEST_*):
# SODEX_PRIVATE_KEY / SODEX_ADDRESS / SODEX_ACCOUNT_ID

# OPTIONAL — Guardian / ops automation ONLY (not user trading identity)
# Leave blank for pure non-custodial relay. Do not use as a shared house account.
SODEX_GUARDIAN_API_KEY_NAME=<REQUEST_FROM_USER>
SODEX_GUARDIAN_API_KEY_PRIVATE_KEY=<REQUEST_FROM_USER>
SODEX_GUARDIAN_MASTER_ADDRESS=<REQUEST_FROM_USER>
# Where: SoDEX addAPIKey flow — https://sodex.com/documentation/trading-api/trading-api
# Why: automated risk-off only; users still sign their own trades

# =============================================================================
# SSI / BASE (official token addresses)
# =============================================================================
BASE_CHAIN_ID=8453
BASE_RPC_URL=https://mainnet.base.org
BASE_EXPLORER=https://basescan.org

SOSO_TOKEN_ETHEREUM=0x76a0e27618462bdac7a29104bdcfff4e6bfcea2d
SOSO_TOKEN_BASE=0x624e2e7fdc8903165f64891672267ab0fcb98831

SSI_APP_URL=https://ssi.sosovalue.com
SSI_EARN_URL=https://ssi.sosovalue.com/earn
SSI_REWARD_URL=https://ssi.sosovalue.com/reward

# SSI app contracts — NOT published as fixed docs constants; discover + verify
SSI_ROUTER_ADDRESS=<REQUEST_FROM_USER>
SSI_STAKING_ADDRESS=<REQUEST_FROM_USER>
SSI_RESEARCH_HUB_VOTING_ADDRESS=<REQUEST_FROM_USER>
# Where: ssi.sosovalue.com wallet tx target → BaseScan verify
# Or: https://github.com/SoSoValueLabs/ssi-protocol

# =============================================================================
# AI PROVIDERS — NVIDIA PRIMARY
# Docs: https://docs.api.nvidia.com/ · https://build.nvidia.com/
# OpenAI-compatible base: https://integrate.api.nvidia.com/v1
# Verify model IDs on build.nvidia.com before changing defaults.
# =============================================================================
NVIDIA_API_KEY=<REQUEST_FROM_USER>
# Where: https://build.nvidia.com/ → Generate API Key
# Official: https://docs.api.nvidia.com/
# Time: 5 min

NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_PRIMARY=deepseek-ai/deepseek-v4-flash
NVIDIA_MODEL_SECONDARY=meta/llama-3.1-70b-instruct
NVIDIA_MODEL_TERTIARY=nvidia/llama-3.1-nemotron-70b-instruct
# Verify secondary/tertiary on https://build.nvidia.com/ if a model is deprecated
NVIDIA_TIMEOUT_MS=120000
NVIDIA_THINKING_ENABLED=true
NVIDIA_REASONING_EFFORT=high

# Fallback chain AFTER all NVIDIA models fail
CEREBRAS_API_KEY=<REQUEST_FROM_USER>
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama-3.3-70b

SAMBANOVA_API_KEY=<REQUEST_FROM_USER>
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct

GROQ_API_KEY=<REQUEST_FROM_USER>
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Optional extra fallbacks (not in primary chain unless enabled)
TOGETHER_API_KEY=<REQUEST_FROM_USER>
OPENROUTER_API_KEY=<REQUEST_FROM_USER>
GOOGLE_GENERATIVE_AI_API_KEY=<REQUEST_FROM_USER>

AI_PRIMARY_PROVIDER=nvidia
AI_FALLBACK_PROVIDERS=cerebras,sambanova,groq
AI_REQUEST_TIMEOUT_MS=120000
AI_MAX_RETRIES=2
AI_CIRCUIT_BREAKER_THRESHOLD=5
AI_CIRCUIT_BREAKER_COOLDOWN_MS=60000

# =============================================================================
# WALLETCONNECT / REOWN (frontend later)
# =============================================================================
REOWN_PROJECT_ID=<REQUEST_FROM_USER>
# Where: https://cloud.reown.com/

# =============================================================================
# NOTIFICATIONS (optional until Guardian/Estate)
# =============================================================================
RESEND_API_KEY=<REQUEST_FROM_USER>
EMAIL_FROM=<REQUEST_FROM_USER>
TELEGRAM_BOT_TOKEN=<REQUEST_FROM_USER>
TELEGRAM_ALLOWED_CHAT_IDS=<REQUEST_FROM_USER>
TWILIO_ACCOUNT_SID=<REQUEST_FROM_USER>
TWILIO_AUTH_TOKEN=<REQUEST_FROM_USER>
TWILIO_FROM_NUMBER=<REQUEST_FROM_USER>

# =============================================================================
# KYC / IPFS / OBSERVABILITY
# =============================================================================
SUMSUB_APP_TOKEN=<REQUEST_FROM_USER>
SUMSUB_SECRET_KEY=<REQUEST_FROM_USER>
PINATA_JWT=<REQUEST_FROM_USER>
SENTRY_DSN=<REQUEST_FROM_USER>

# =============================================================================
# FRONTEND (Vite) — deferred until backend DoD; do not put server secrets here
# =============================================================================
VITE_API_URL=http://localhost:10000
VITE_DEFAULT_ENVIRONMENT=mainnet
VITE_REOWN_PROJECT_ID=<REQUEST_FROM_USER>
VITE_VALUECHAIN_CHAIN_ID=286623
VITE_VALUECHAIN_RPC=https://mainnet.valuechain.xyz
VITE_VALUECHAIN_EXPLORER=https://main-scan.valuechain.xyz
VITE_VALUECHAIN_NATIVE_SYMBOL=SOSO
VITE_SODEX_APP_URL=https://sodex.com
VITE_SSI_APP_URL=https://ssi.sosovalue.com
VITE_WSOSO_ADDRESS=0x5050505050505050505050505050505050505050
VITE_BASE_CHAIN_ID=8453
